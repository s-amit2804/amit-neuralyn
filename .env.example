# ── Azure OpenAI (Whisper large-v3) ──────────────────────────────────────────
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_WHISPER_DEPLOYMENT_NAME=your-whisper-deployment-name
AZURE_OPENAI_API_VERSION=2024-06-01

# ── OpenRouter LLM ─────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=MindBridge
OPENROUTER_SITE_URL=https://mindbridge.local
CHAT_MODEL_ID=qwen3.5-397b-a17b
CHAT_FALLBACK_MODEL_ID=openai/gpt-4o-mini
CHAT_LLM_TIMEOUT_MS=20000
CLAUDE_MODEL_ID=qwen3.5-397b-a17b

# ── MentalRoBERTa (optional override — default loads from HuggingFace) ──────
MENTAL_ROBERTA_MODEL=mental/mental-roberta-base
